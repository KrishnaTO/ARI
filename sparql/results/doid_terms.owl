    <!-- http://purl.obolibrary.org/obo/DOID_0111079 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/DOID_0111079">
        <obo:IAO_0000115 xml:lang="en">A posterior uveitis characterized by multiple small, hypopigmented, cream-colored choroidal lesions scattered symmetrically in the fundus primarily around the optic disc that presents in patients as blurred vision, floaters, photopsia, scotoma and nyctalopia.</obo:IAO_0000115>
        <obo:IAO_0000115 xml:lang="es">La uveítis posterior se caracteriza por múltiples lesiones coroideas pequeñas, hipopigmentadas y de color crema, diseminadas simétricamente en el fondo de ojo principalmente alrededor del disco óptico, que se presenta en los pacientes como visión borrosa, moscas volantes, fotopsia, escotoma y nictalopía.</obo:IAO_0000115>
        <oboInOwl:hasDbXref>GARD:5926</oboInOwl:hasDbXref>
        <oboInOwl:hasDbXref>MESH:D000080365</oboInOwl:hasDbXref>
