    <!-- http://purl.obolibrary.org/obo/DOID_0060191 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/DOID_0060191">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/DOID_0050589"/>
        <obo:IAO_0000115 xml:lang="en">An inflammatory bowel disease characterized by inflammation located_in stomach and located_in duodenum, has_symptom nausea, has_symptom vomiting, has_symptom weight loss and has_symptom loss of appetite.</obo:IAO_0000115>
        <obo:IAO_0000115 xml:lang="es">Enfermedad inflamatoria intestinal caracterizada por inflamación que se_ubica_en el estómago y se_ubica_en el duodeno, tiene_como_síntoma náuseas, tiene_como_síntoma vómitos, tiene_como_síntoma pérdida de peso y tiene_como_síntoma pérdida de apetito.</obo:IAO_0000115>
        <oboInOwl:creation_date>2014-09-15T12:35:28Z</oboInOwl:creation_date>
        <oboInOwl:hasDbXref>ICD10CM:K50.0</oboInOwl:hasDbXref>
