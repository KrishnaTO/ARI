    <owl:Ontology rdf:about="http://purl.obolibrary.org/obo/doid/translations/doid-international.owl">
        <obo:IAO_0000700 rdf:resource="http://purl.obolibrary.org/obo/DOID_4"/>
        <dc:description xml:lang="es">La Disease Ontology se ha desarrollado como una ontología estandarizada para las enfermedades humanas con el propósito de proporcionar a la comunidad biomédica descripciones coherentes, reutilizables y sostenibles de términos de enfermedades humanas, características de fenotipos y conceptos de enfermedades del vocabulario médico relacionados.</dc:description>
        <dc:description xml:lang="en">The Disease Ontology has been developed as a standardized ontology for human disease with the purpose of providing the biomedical community with consistent, reusable and sustainable descriptions of human disease terms, phenotype characteristics and related medical vocabulary disease concepts.</dc:description>
        <dc:language>en</dc:language>
        <dc:language>es</dc:language>
        <dc:title>Human Disease Ontology</dc:title>
        <terms:license rdf:resource="https://creativecommons.org/publicdomain/zero/1.0/"/>
        <oboInOwl:date>28:02:2026 20:09</oboInOwl:date>
        <oboInOwl:default-namespace>disease_ontology</oboInOwl:default-namespace>
        <oboInOwl:hasOBOFormatVersion>1.2</oboInOwl:hasOBOFormatVersion>
        <oboInOwl:saved-by>lschriml</oboInOwl:saved-by>
        <rdfs:comment xml:lang="en">The Disease Ontology content is available via the Creative Commons Public Domain Dedication CC0 1.0 Universal license (https://creativecommons.org/publicdomain/zero/1.0/).</rdfs:comment>
        <owl:versionInfo>2026-02-28</owl:versionInfo>
    </owl:Ontology>
    


