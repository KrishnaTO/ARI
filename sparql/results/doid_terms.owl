        <oboInOwl:hasDbXref>MESH:D003424</oboInOwl:hasDbXref>
        <oboInOwl:hasDbXref>NCI:C37262</oboInOwl:hasDbXref>
        <oboInOwl:hasDbXref>SNOMEDCT_US_2023_03_01:7620006</oboInOwl:hasDbXref>
        <oboInOwl:hasDbXref>UMLS_CUI:C0156147</oboInOwl:hasDbXref>
