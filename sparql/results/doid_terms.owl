    <!-- http://purl.obolibrary.org/obo/DOID_0080750 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/DOID_0080750">
        <obo:IAO_0000115 xml:lang="en">A panniculitis that is characterized by sudden onset of painful, erythematous, subcutaneous nodules mainly localized to the pretibial areas. Lesions are usually bilateral and symmetrical, ranging from 1 to 5 cm in diameter.</obo:IAO_0000115>
        <obo:IAO_0000115 xml:lang="es">Paniculitis que se caracteriza por la aparición súbita de nódulos subcutáneos eritematosos y dolorosos localizados principalmente en las zonas pretibiales. Las lesiones suelen ser bilaterales y simétricas, y su diámetro oscila entre 1 y 5 cm.</obo:IAO_0000115>
        <oboInOwl:hasDbXref>MESH:D004893</oboInOwl:hasDbXref>
        <oboInOwl:hasOBONamespace>disease_ontology</oboInOwl:hasOBONamespace>
        <oboInOwl:id>DOID:0080750</oboInOwl:id>
        <rdfs:label xml:lang="es">eritema nodoso</rdfs:label>
        <rdfs:label xml:lang="en">erythema nodosum</rdfs:label>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://purl.obolibrary.org/obo/DOID_0080750"/>
        <owl:annotatedProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000115"/>
        <owl:annotatedTarget xml:lang="en">A panniculitis that is characterized by sudden onset of painful, erythematous, subcutaneous nodules mainly localized to the pretibial areas. Lesions are usually bilateral and symmetrical, ranging from 1 to 5 cm in diameter.</owl:annotatedTarget>
        <oboInOwl:hasDbXref>url:https://en.wikipedia.org/wiki/Erythema_nodosum</oboInOwl:hasDbXref>
        <oboInOwl:hasDbXref>url:https://pubmed.ncbi.nlm.nih.gov/30269303/</oboInOwl:hasDbXref>
    </owl:Axiom>
    


