        <owl:annotatedTarget xml:lang="en">A multiple sclerosis that is characterized by steady worsening of neurologic functioning, without any distinct relapses or periods of remission. The rate of progression may vary over time, with occasional plateaus or temporary improvements, but the progression is continuous.</owl:annotatedTarget>
        <dc:type rdf:resource="http://purl.obolibrary.org/obo/ECO_0007637"/>
