    <!-- http://purl.obolibrary.org/obo/DOID_0050214 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/DOID_0050214">
        <obo:IAO_0000115 xml:lang="en">A neuromuscular junction disease that is characterized by an abnormality of acetylcholine (ACh) release at the neuromuscular junction which results from an autoimmune attack against voltage-gated calcium channels (VGCC) on the presynaptic motor nerve terminal.</obo:IAO_0000115>
        <obo:IAO_0000115 xml:lang="es">Enfermedad de la unión neuromuscular que se caracteriza por una anomalía de la liberación de acetilcolina (ACh) en la unión neuromuscular que resulta de un ataque autoinmune contra los canales de calcio activados por voltaje (VGCC) en la terminal nerviosa motora presináptica.</obo:IAO_0000115>
