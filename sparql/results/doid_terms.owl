    <owl:Class rdf:about="http://purl.obolibrary.org/obo/DOID_0040097">
        <obo:IAO_0000115 xml:lang="en">An autoimmune disease of cardiovascular system that is characterized by inflammation of the blood vessels.</obo:IAO_0000115>
