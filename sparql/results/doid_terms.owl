    <owl:Class rdf:about="http://purl.obolibrary.org/obo/DOID_0111157">
        <obo:IAO_0000115 xml:lang="en">A lymphoproliferative syndrome characterized by one or more enlarged lymph nodes containing cells with hyaline-vascular, plasmacytic, or mixed appearance microscopically.</obo:IAO_0000115>
        <obo:IAO_0000115 xml:lang="es">El síndrome linfoproliferativo se caracteriza por uno o más ganglios linfáticos agrandados que contienen células con aspecto hialino-vascular, plasmocitario o mixto microscópicamente.</obo:IAO_0000115>
