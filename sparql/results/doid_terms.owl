    <!-- http://purl.obolibrary.org/obo/DOID_0050167 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/DOID_0050167">
        <obo:IAO_0000115 xml:lang="en">An autoimmune polyendocrine syndrome that is inherited in an autosomal recessive fashion, which is characterized by abnormal functioning of the immune system that causes auto-reactivity against endocrine organs.</obo:IAO_0000115>
        <obo:IAO_0000115 xml:lang="es">Síndrome polendocrino autoinmune que se hereda de forma autosómica recesiva y que se caracteriza por un funcionamiento anormal del sistema inmunitario que provoca una autorreactividad contra los órganos endocrinos.</obo:IAO_0000115>
        <oboInOwl:hasDbXref>GARD:8466</oboInOwl:hasDbXref>
        <oboInOwl:hasDbXref>MIM:240300</oboInOwl:hasDbXref>
        <oboInOwl:hasExactSynonym xml:lang="en">Autoimmune Polyglandular Syndrome I</oboInOwl:hasExactSynonym>
        <oboInOwl:hasExactSynonym xml:lang="en">Whitaker syndrome</oboInOwl:hasExactSynonym>
        <oboInOwl:hasExactSynonym xml:lang="en">autoimmune polyendocrinopathy-candidiasis-ectodermal dystrophy</oboInOwl:hasExactSynonym>
        <oboInOwl:hasExactSynonym xml:lang="es">síndrome de Whitaker</oboInOwl:hasExactSynonym>
        <oboInOwl:hasOBONamespace>disease_ontology</oboInOwl:hasOBONamespace>
        <oboInOwl:id>DOID:0050167</oboInOwl:id>
        <oboInOwl:inSubset rdf:resource="http://purl.obolibrary.org/obo/doid#DO_rare_slim"/>
        <rdfs:label xml:lang="en">autoimmune polyendocrine syndrome type 1</rdfs:label>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://purl.obolibrary.org/obo/DOID_0050167"/>
        <owl:annotatedProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000115"/>
        <owl:annotatedTarget xml:lang="en">An autoimmune polyendocrine syndrome that is inherited in an autosomal recessive fashion, which is characterized by abnormal functioning of the immune system that causes auto-reactivity against endocrine organs.</owl:annotatedTarget>
        <dc:type rdf:resource="http://purl.obolibrary.org/obo/ECO_0007637"/>
