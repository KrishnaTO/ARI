        <oboInOwl:hasExactSynonym xml:lang="es">Orbitopatía de Graves</oboInOwl:hasExactSynonym>
        <oboInOwl:hasExactSynonym xml:lang="en">Thyroid associated ophthalmopathy</oboInOwl:hasExactSynonym>
        <oboInOwl:hasExactSynonym xml:lang="es">enfermedad ocular tiroidea</oboInOwl:hasExactSynonym>
        <oboInOwl:hasExactSynonym xml:lang="en">thyroid eye disease</oboInOwl:hasExactSynonym>
        <oboInOwl:hasOBONamespace>disease_ontology</oboInOwl:hasOBONamespace>
