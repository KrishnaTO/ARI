    <!-- http://purl.obolibrary.org/obo/DOID_0081120 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/DOID_0081120">
        <obo:IAO_0000115 xml:lang="en">An autoimmune disease of eyes, ear, nose and throat that is characterized by upper eyelid retraction, lid lag, swelling, redness, conjunctivitis, and bulging eyes.</obo:IAO_0000115>
        <obo:IAO_0000115 xml:lang="es">Enfermedad autoinmune de ojos, oído, nariz y garganta que se caracteriza por retracción del párpado superior, lag del párpado, hinchazón, enrojecimiento, conjuntivitis y ojos saltones.</obo:IAO_0000115>
        <oboInOwl:hasDbXref>MESH:D049970</oboInOwl:hasDbXref>
        <oboInOwl:hasExactSynonym xml:lang="en">Graves orbitopathy</oboInOwl:hasExactSynonym>
