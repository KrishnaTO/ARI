    <!-- http://purl.obolibrary.org/obo/DOID_0060215 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/DOID_0060215">
        <obo:IAO_0000115 xml:lang="en">A multiple sclerosis that is characterized by concentric layers of demyelinated tissues, tumor-like lesions larger than two centimeters and symptoms similar to those of a brain tumor.</obo:IAO_0000115>
        <obo:IAO_0000115 xml:lang="es">Esclerosis múltiple que se caracteriza por capas concéntricas de tejidos desmielinizados, lesiones de aspecto tumoral de más de dos centímetros y síntomas similares a los de un tumor cerebral.</obo:IAO_0000115>
        <oboInOwl:creation_date>2014-09-18T15:02:17Z</oboInOwl:creation_date>
