        <oboInOwl:hasExactSynonym xml:lang="en">BSCR</oboInOwl:hasExactSynonym>
        <oboInOwl:hasExactSynonym xml:lang="en">birdshot chorioretinitis</oboInOwl:hasExactSynonym>
        <oboInOwl:hasExactSynonym xml:lang="en">birdshot retinochoroiditis</oboInOwl:hasExactSynonym>
        <oboInOwl:hasExactSynonym xml:lang="en">birdshot retinochoroidopathy</oboInOwl:hasExactSynonym>
        <oboInOwl:hasExactSynonym xml:lang="en">vitiliginous choroiditis</oboInOwl:hasExactSynonym>
        <oboInOwl:hasOBONamespace>disease_ontology</oboInOwl:hasOBONamespace>
