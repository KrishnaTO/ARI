    <!-- http://purl.obolibrary.org/obo/DOID_0080356 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/DOID_0080356">
        <obo:IAO_0000115 xml:lang="en">An autoimmune disease that is characterized by tumefactive lesions, a dense lymphoplasmacytic infiltrate rich in IgG4-positive plasma cells, storiform fibrosis, obliterative phlebitis, autoimmune pancreatitis, and sometimes elevated serum IgG4 levels affecting various organs.</obo:IAO_0000115>
        <obo:IAO_0000115 xml:lang="es">Enfermedad autoinmune que se caracteriza por lesiones tumefactivas, un denso infiltrado linfoplasmocitario rico en células plasmáticas IgG4 positivas, fibrosis estoriforme, flebitis obliterativa, pancreatitis autoinmune y, en ocasiones, niveles séricos elevados de IgG4 que afectan a diversos órganos.</obo:IAO_0000115>
        <oboInOwl:hasDbXref>GARD:12521</oboInOwl:hasDbXref>
        <oboInOwl:hasDbXref>ORDO:284264</oboInOwl:hasDbXref>
        <oboInOwl:hasOBONamespace>disease_ontology</oboInOwl:hasOBONamespace>
        <oboInOwl:id>DOID:0080356</oboInOwl:id>
        <oboInOwl:inSubset rdf:resource="http://purl.obolibrary.org/obo/doid#DO_rare_slim"/>
        <rdfs:label xml:lang="en">IgG4-related disease</rdfs:label>
        <rdfs:label xml:lang="es">enfermedad relacionada con IgG4</rdfs:label>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://purl.obolibrary.org/obo/DOID_0080356"/>
        <owl:annotatedProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000115"/>
        <owl:annotatedTarget xml:lang="en">An autoimmune disease that is characterized by tumefactive lesions, a dense lymphoplasmacytic infiltrate rich in IgG4-positive plasma cells, storiform fibrosis, obliterative phlebitis, autoimmune pancreatitis, and sometimes elevated serum IgG4 levels affecting various organs.</owl:annotatedTarget>
        <dc:type rdf:resource="http://purl.obolibrary.org/obo/ECO_0007637"/>
        <dc:type rdf:resource="http://purl.obolibrary.org/obo/ECO_0007645"/>
        <oboInOwl:hasDbXref>url:https://rarediseases.info.nih.gov/diseases/12521/index</oboInOwl:hasDbXref>
        <oboInOwl:hasDbXref>url:https://www.ncbi.nlm.nih.gov/articles/PMC4760655/</oboInOwl:hasDbXref>
        <oboInOwl:hasDbXref>url:https://www.nejm.org/doi/full/10.1056/NEJMra1104650</oboInOwl:hasDbXref>
    </owl:Axiom>
    


