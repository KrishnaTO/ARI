    <!-- http://purl.obolibrary.org/obo/DOID_0080848 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/DOID_0080848">
        <obo:IAO_0000115 xml:lang="en">A Coronavirus infectious disease that is characterized by long-term persistent and fluctuating symptoms, in individuals with COVID-19, persisting beyond three to four weeks, including the loss of the ability to smell and taste, breathlessness, fatigue, difficulty in breathing, difficulty concentrating, memory loss, confusion, headache, heart palpitations, chest pain, pain with deep breaths, dizziness, and tachycardia.</obo:IAO_0000115>
        <obo:IAO_0000115 xml:lang="es">Enfermedad infecciosa por Coronavirus que se caracteriza por síntomas persistentes y fluctuantes a largo plazo, en individuos con COVID-19, que persisten más allá de tres o cuatro semanas, incluyendo la pérdida de la capacidad olfativa y gustativa, disnea, fatiga, dificultad para respirar, dificultad para concentrarse, pérdida de memoria, confusión, dolor de cabeza, palpitaciones, dolor torácico, dolor con respiraciones profundas, mareos y taquicardia.</obo:IAO_0000115>
        <oboInOwl:hasExactSynonym xml:lang="es">COVID-19 crónico</oboInOwl:hasExactSynonym>
        <oboInOwl:hasExactSynonym xml:lang="en">PASC</oboInOwl:hasExactSynonym>
        <oboInOwl:hasExactSynonym xml:lang="en">chronic COVID-19</oboInOwl:hasExactSynonym>
        <oboInOwl:hasExactSynonym xml:lang="en">post-COVID syndrome</oboInOwl:hasExactSynonym>
        <oboInOwl:hasExactSynonym xml:lang="en">post-acute sequelae of SARS-CoV-2 infection</oboInOwl:hasExactSynonym>
        <oboInOwl:hasExactSynonym xml:lang="es">secuelas posagudas de la infección por SARS-CoV-2</oboInOwl:hasExactSynonym>
        <oboInOwl:hasExactSynonym xml:lang="es">síndrome post-COVID</oboInOwl:hasExactSynonym>
        <oboInOwl:hasOBONamespace>disease_ontology</oboInOwl:hasOBONamespace>
        <oboInOwl:id>DOID:0080848</oboInOwl:id>
        <oboInOwl:inSubset rdf:resource="http://purl.obolibrary.org/obo/doid#DO_infectious_disease_slim"/>
        <rdfs:label xml:lang="es">COVID largo</rdfs:label>
        <rdfs:label xml:lang="en">long COVID</rdfs:label>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://purl.obolibrary.org/obo/DOID_0080848"/>
        <owl:annotatedProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000115"/>
        <owl:annotatedTarget xml:lang="en">A Coronavirus infectious disease that is characterized by long-term persistent and fluctuating symptoms, in individuals with COVID-19, persisting beyond three to four weeks, including the loss of the ability to smell and taste, breathlessness, fatigue, difficulty in breathing, difficulty concentrating, memory loss, confusion, headache, heart palpitations, chest pain, pain with deep breaths, dizziness, and tachycardia.</owl:annotatedTarget>
        <oboInOwl:hasDbXref>url:https://www.bmj.com/content/371/bmj.m4470</oboInOwl:hasDbXref>
        <oboInOwl:hasDbXref>url:https://www.medrxiv.org/content/10.1101/2020.10.07.20208249v1</oboInOwl:hasDbXref>
        <oboInOwl:hasDbXref>url:https://www.medrxiv.org/content/10.1101/2020.10.07.20208702v1</oboInOwl:hasDbXref>
        <oboInOwl:hasDbXref>url:https://www.medrxiv.org/content/10.1101/2020.10.13.20211854v1</oboInOwl:hasDbXref>
        <oboInOwl:hasDbXref>url:https://www.nature.com/articles/d41586-020-02796-2</oboInOwl:hasDbXref>
    </owl:Axiom>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://purl.obolibrary.org/obo/DOID_0080848"/>
        <owl:annotatedProperty rdf:resource="http://www.geneontology.org/formats/oboInOwl#hasExactSynonym"/>
        <owl:annotatedTarget xml:lang="en">PASC</owl:annotatedTarget>
        <oboInOwl:hasSynonymType rdf:resource="http://purl.obolibrary.org/obo/OMO_0003012"/>
    </owl:Axiom>
    


    <!-- http://purl.obolibrary.org/obo/DOID_0080850 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/DOID_0080850">
        <obo:IAO_0000115 xml:lang="en">A pemphigus that is characterized by blistering lesions on otherwise healthy-looking skin.</obo:IAO_0000115>
        <obo:IAO_0000115 xml:lang="es">Pénfigo caracterizado por lesiones ampollosas en una piel de aspecto sano.</obo:IAO_0000115>
