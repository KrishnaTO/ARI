        <rdfs:label xml:lang="en">Graves ophthalmopathy</rdfs:label>
        <rdfs:label xml:lang="es">Oftalmopatía de Graves</rdfs:label>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://purl.obolibrary.org/obo/DOID_0081120"/>
