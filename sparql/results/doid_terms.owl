    <!-- http://purl.obolibrary.org/obo/DOID_0060192 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/DOID_0060192">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/DOID_0050589"/>
        <obo:IAO_0000115 xml:lang="en">An inflammatory bowel disease characterized by inflammation located_in colon only, has_symptom diarrhea, has_symptom rectal bleeding, has_symptom skin lesions and has_symptom formation of ulcers, fistulas and abscesses around the anus.</obo:IAO_0000115>
        <obo:IAO_0000115 xml:lang="es">Enfermedad inflamatoria intestinal caracterizada por una inflamación que se_ubica_en el colon únicamente, tiene_como_síntoma diarrea, tiene_como_síntoma hemorragia rectal, tiene_como_síntoma lesiones cutáneas y tiene_como_síntoma formación de úlceras, fístulas y abscesos alrededor del ano.</obo:IAO_0000115>
        <oboInOwl:creation_date>2014-09-15T12:50:24Z</oboInOwl:creation_date>
        <oboInOwl:hasDbXref>ICD10CM:K50.1</oboInOwl:hasDbXref>
