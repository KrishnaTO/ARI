        <oboInOwl:hasOBONamespace>disease_ontology</oboInOwl:hasOBONamespace>
        <oboInOwl:id>DOID:0060191</oboInOwl:id>
        <rdfs:label xml:lang="es">enfermedad de Crohn gastroduodenal</rdfs:label>
        <rdfs:label xml:lang="en">gastroduodenal Crohn&apos;s disease</rdfs:label>
    </owl:Class>
