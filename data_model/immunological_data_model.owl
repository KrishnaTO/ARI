<?xml version="1.0"?>
<rdf:RDF xmlns="http://www.aurint.org/ontologies/immunological-data-model#"
     xml:base="http://www.aurint.org/ontologies/immunological-data-model"
     xmlns:imo="http://www.aurint.org/ontologies/immunological-data-model#"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:xml="http://www.w3.org/XML/1998/namespace"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#">
    <owl:Ontology rdf:about="http://www.aurint.org/ontologies/immunological-data-model">
        <rdfs:comment xml:lang="en">An OWL 2 ontology representing the immunological disease data model, covering disease identity, etiology, innate and adaptive immunity, signalling, pathophysiology, clinical profile, evidence, epidemiology, biomarkers, and standard terminology codes.</rdfs:comment>
        <rdfs:label xml:lang="en">Immunological Disease Data Model Ontology</rdfs:label>
    </owl:Ontology>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Object Properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://www.aurint.org/ontologies/immunological-data-model#affectsCellTissueOrOrgan -->

    <owl:ObjectProperty rdf:about="http://www.aurint.org/ontologies/immunological-data-model#affectsCellTissueOrOrgan">
        <rdfs:domain rdf:resource="http://www.aurint.org/ontologies/immunological-data-model#ImmunologicalDisease"/>
        <rdfs:range rdf:resource="http://www.aurint.org/ontologies/immunological-data-model#AffectedCellTissueOrOrgan"/>
        <rdfs:comment xml:lang="en">Specific cells, tissues, or organs damaged by the immune-mediated process.</rdfs:comment>
        <rdfs:label xml:lang="en">affects cell, tissue or organ</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.aurint.org/ontologies/immunological-data-model#associatedWithAutoimmune -->

    <owl:ObjectProperty rdf:about="http://www.aurint.org/ontologies/immunological-data-model#associatedWithAutoimmune">
        <rdfs:domain rdf:resource="http://www.aurint.org/ontologies/immunological-data-model#ImmunologicalDisease"/>
        <rdfs:range rdf:resource="http://www.aurint.org/ontologies/immunological-data-model#AutoimmuneDisease"/>
        <rdfs:comment xml:lang="en">Co-occurring or overlapping autoimmune conditions observed in patients with this disease.</rdfs:comment>
        <rdfs:label xml:lang="en">associated with autoimmune disease</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.aurint.org/ontologies/immunological-data-model#hasAcutePhaseReactant -->

    <owl:ObjectProperty rdf:about="http://www.aurint.org/ontologies/immunological-data-model#hasAcutePhaseReactant">
        <rdfs:domain rdf:resource="http://www.aurint.org/ontologies/immunological-data-model#ImmunologicalDisease"/>
        <rdfs:range rdf:resource="http://www.aurint.org/ontologies/immunological-data-model#AcutePhaseReactant"/>
        <rdfs:label xml:lang="en">has acute phase reactant</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.aurint.org/ontologies/immunological-data-model#hasAnimalCellEvidence -->

    <owl:ObjectProperty rdf:about="http://www.aurint.org/ontologies/immunological-data-model#hasAnimalCellEvidence">
        <rdfs:domain rdf:resource="http://www.aurint.org/ontologies/immunological-data-model#ImmunologicalDisease"/>
        <rdfs:range rdf:resource="http://www.aurint.org/ontologies/immunological-data-model#InVitroAnimalCellEvidence"/>
        <rdfs:label xml:lang="en">has in vitro animal cell evidence</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.aurint.org/ontologies/immunological-data-model#hasAutoantibody -->

    <owl:ObjectProperty rdf:about="http://www.aurint.org/ontologies/immunological-data-model#hasAutoantibody">
        <rdfs:domain rdf:resource="http://www.aurint.org/ontologies/immunological-data-model#ImmunologicalDisease"/>
        <rdfs:range rdf:resource="http://www.aurint.org/ontologies/immunological-data-model#Antibody"/>
        <rdfs:comment xml:lang="en">Autoantibodies produced in the disease, with diagnostic and/or pathogenic relevance.</rdfs:comment>
        <rdfs:label xml:lang="en">has autoantibody</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.aurint.org/ontologies/immunological-data-model#hasBiomarker -->

    <owl:ObjectProperty rdf:about="http://www.aurint.org/ontologies/immunological-data-model#hasBiomarker">
        <rdfs:domain rdf:resource="http://www.aurint.org/ontologies/immunological-data-model#ImmunologicalDisease"/>
        <rdfs:range rdf:resource="http://www.aurint.org/ontologies/immunological-data-model#Biomarker"/>
        <rdfs:label xml:lang="en">has biomarker</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.aurint.org/ontologies/immunological-data-model#hasCardinalSymptom -->

    <owl:ObjectProperty rdf:about="http://www.aurint.org/ontologies/immunological-data-model#hasCardinalSymptom">
