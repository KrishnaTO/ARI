        <rdfs:range rdf:resource="http://www.aurint.org/ontologies/immunological-data-model#CardinalSymptom"/>
        <rdfs:label xml:lang="en">has cardinal symptom</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.aurint.org/ontologies/immunological-data-model#hasCaseReport -->

    <owl:ObjectProperty rdf:about="http://www.aurint.org/ontologies/immunological-data-model#hasCaseReport">
