    </owl:ObjectProperty>
    


    <!-- http://www.aurint.org/ontologies/immunological-data-model#hasClinicalFeature -->

    <owl:ObjectProperty rdf:about="http://www.aurint.org/ontologies/immunological-data-model#hasClinicalFeature">
        <rdfs:domain rdf:resource="http://www.aurint.org/ontologies/immunological-data-model#ImmunologicalDisease"/>
        <rdfs:range rdf:resource="http://www.aurint.org/ontologies/immunological-data-model#ClinicalFeature"/>
        <rdfs:label xml:lang="en">has clinical feature</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.aurint.org/ontologies/immunological-data-model#hasEnvironmentalTrigger -->

