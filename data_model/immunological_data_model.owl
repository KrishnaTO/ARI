        <rdfs:range rdf:resource="http://www.aurint.org/ontologies/immunological-data-model#EvidenceRecord"/>
        <rdfs:label xml:lang="en">has evidence record</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.aurint.org/ontologies/immunological-data-model#hasGeneRegion -->

    <owl:ObjectProperty rdf:about="http://www.aurint.org/ontologies/immunological-data-model#hasGeneRegion">
        <rdfs:domain rdf:resource="http://www.aurint.org/ontologies/immunological-data-model#ImmunologicalDisease"/>
