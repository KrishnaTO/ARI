    <!-- http://www.aurint.org/ontologies/immunological-data-model#hasHLAAssociation -->

    <owl:ObjectProperty rdf:about="http://www.aurint.org/ontologies/immunological-data-model#hasHLAAssociation">
        <rdfs:domain rdf:resource="http://www.aurint.org/ontologies/immunological-data-model#ImmunologicalDisease"/>
        <rdfs:range rdf:resource="http://www.aurint.org/ontologies/immunological-data-model#HLAGeneRegion"/>
        <rdfs:comment xml:lang="en">Associates a disease with specific HLA alleles conferring risk or protection.</rdfs:comment>
        <rdfs:label xml:lang="en">has HLA association</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.aurint.org/ontologies/immunological-data-model#hasHumanCellEvidence -->

